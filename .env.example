# Resonate Backend API
# Live staging (public agent surface — storefront/catalog/x402/MCP, no auth):
#   $RESONATE_API_BASE   (MCP at /mcp, spec at /openapi.json)
RESONATE_API_BASE=http://localhost:3000
RESONATE_API_KEY=

# Google AI / Gemini
# --- Option A: AI Studio (local dev) ---
GOOGLE_API_KEY=your-google-api-key
# --- Option B: Gemini Enterprise Agent Platform / Vertex AI backend (production) — preferred ---
# (GOOGLE_GENAI_USE_VERTEXAI is the genai SDK flag; unchanged by the 2026 rebrand)
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# GOOGLE_CLOUD_LOCATION=us-central1
AGENT_MODEL=gemini-2.5-flash

# x402 Payment Configuration
X402_NETWORK=eip155:84532
X402_FACILITATOR_URL=https://x402.org/facilitator

# Agent Defaults
AGENT_DEFAULT_BUDGET_USD=50.0
AGENT_RECOMMENDATION_STRATEGY=deterministic
